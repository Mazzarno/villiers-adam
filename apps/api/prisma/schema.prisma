generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN_MAIRIE
  AGENT
  CONTRIBUTOR
  READER
}

enum ContentStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum DirectoryType {
  ASSOCIATION
  ENTERPRISE
  COMMERCE
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum ArticleType {
  ACTUALITE
  PUBLICATION
  BREVE
}

enum PublicationType {
  ARRETE
  COMPTE_RENDU
  DELIBERATION
}

enum CouncilMemberRole {
  MAIRE
  ADJOINT
  CONSEILLER
  CONSEILLER_DELEGUE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PUBLISH
  ARCHIVE
  RESTORE
  EXPORT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  avatarUrl    String?
  role         UserRole @default(READER)
  mfaEnabled   Boolean  @default(false)
  mfaSecret    String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdArticles        Article[]        @relation("ArticleCreatedBy")
  updatedArticles        Article[]        @relation("ArticleUpdatedBy")
  createdEvents          Event[]          @relation("EventCreatedBy")
  updatedEvents          Event[]          @relation("EventUpdatedBy")
  createdDirectoryEntries DirectoryEntry[] @relation("DirectoryCreatedBy")
  updatedDirectoryEntries DirectoryEntry[] @relation("DirectoryUpdatedBy")
  createdProcedures      Procedure[]      @relation("ProcedureCreatedBy")
  updatedProcedures      Procedure[]      @relation("ProcedureUpdatedBy")
  createdCouncilMembers  CouncilMember[]  @relation("CouncilCreatedBy")
  updatedCouncilMembers  CouncilMember[]  @relation("CouncilUpdatedBy")
  createdMunicipalServices MunicipalService[] @relation("ServiceCreatedBy")
  updatedMunicipalServices MunicipalService[] @relation("ServiceUpdatedBy")
  createdTransportInfos  TransportInfo[]  @relation("TransportCreatedBy")
  updatedTransportInfos  TransportInfo[]  @relation("TransportUpdatedBy")
  createdMedia           Media[]          @relation("MediaCreatedBy")
  sessions               Session[]
  passwordResetTokens    PasswordResetToken[]
  notifications          Notification[]
  exportArchives         ExportArchive[]  @relation("ExportCreatedBy")

  auditLogs AuditLog[]
  versions  Version[]

  @@index([email])
  @@index([role])
}

model Article {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  summary      String?
  content      Json
  metaTitle    String?
  metaDescription String?
  type         ArticleType   @default(ACTUALITE)
  publicationType PublicationType?
  documentMediaId String?
  documentNumber String?
  meetingDate  DateTime?
  publicationYear Int?
  isFlash      Boolean       @default(false)
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  coverMediaId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  String
  updatedById  String?

  createdBy User   @relation("ArticleCreatedBy", fields: [createdById], references: [id])
  updatedBy User?  @relation("ArticleUpdatedBy", fields: [updatedById], references: [id])
  coverMedia Media? @relation("ArticleCoverMedia", fields: [coverMediaId], references: [id])
  documentMedia Media? @relation("ArticleDocumentMedia", fields: [documentMediaId], references: [id])
  media      ArticleMedia[]

  @@index([status, publishedAt])
  @@index([scheduledAt])
}

model Event {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  summary      String?
  content      Json
  metaTitle    String?
  metaDescription String?
  locationName String?
  address      String?
  latitude     Float?
  longitude    Float?
  startsAt     DateTime
  endsAt       DateTime?
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  coverMediaId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  String
  updatedById  String?

  createdBy User   @relation("EventCreatedBy", fields: [createdById], references: [id])
  updatedBy User?  @relation("EventUpdatedBy", fields: [updatedById], references: [id])
  coverMedia Media? @relation("EventCoverMedia", fields: [coverMediaId], references: [id])
  media      EventMedia[]

  @@index([status, publishedAt])
  @@index([scheduledAt])
  @@index([startsAt])
}

model DirectoryEntry {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  type         DirectoryType
  description  String?
  phone        String?
  email        String?
  website      String?
  addressLine1 String?
  addressLine2 String?
  postalCode   String?
  city         String?
  country      String?
  latitude     Float?
  longitude    Float?
  openingHours Json?
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  coverMediaId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  String
  updatedById  String?

  createdBy User   @relation("DirectoryCreatedBy", fields: [createdById], references: [id])
  updatedBy User?  @relation("DirectoryUpdatedBy", fields: [updatedById], references: [id])
  coverMedia Media? @relation("DirectoryCoverMedia", fields: [coverMediaId], references: [id])
  media      DirectoryEntryMedia[]

  @@index([type])
  @@index([status, publishedAt])
  @@index([scheduledAt])
}

model Procedure {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  summary      String?
  content      Json
  steps        Json?
  externalUrl  String?
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  coverMediaId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  String
  updatedById  String?

  createdBy User   @relation("ProcedureCreatedBy", fields: [createdById], references: [id])
  updatedBy User?  @relation("ProcedureUpdatedBy", fields: [updatedById], references: [id])
  coverMedia Media? @relation("ProcedureCoverMedia", fields: [coverMediaId], references: [id])
  media      ProcedureMedia[]

  @@index([status, publishedAt])
  @@index([scheduledAt])
}

model CouncilMember {
  id           String             @id @default(cuid())
  name         String
  role         CouncilMemberRole
  roleTitle    String?
  delegations  String?
  bio          String?
  email        String?
  phone        String?
  order        Int                @default(0)
  status       ContentStatus      @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  photoMediaId String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  createdById  String
  updatedById  String?

  createdBy User   @relation("CouncilCreatedBy", fields: [createdById], references: [id])
  updatedBy User?  @relation("CouncilUpdatedBy", fields: [updatedById], references: [id])
  photoMedia Media? @relation("CouncilMemberPhoto", fields: [photoMediaId], references: [id])

  @@index([role])
  @@index([status, publishedAt])
  @@index([scheduledAt])
}

model MunicipalService {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  description  String?
  category     String?
  openingHours Json?
  address      String?
  phone        String?
  email        String?
  website      String?
  order        Int           @default(0)
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  coverMediaId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  String
  updatedById  String?

  createdBy User   @relation("ServiceCreatedBy", fields: [createdById], references: [id])
  updatedBy User?  @relation("ServiceUpdatedBy", fields: [updatedById], references: [id])
  coverMedia Media? @relation("ServiceCoverMedia", fields: [coverMediaId], references: [id])

  @@index([status, publishedAt])
  @@index([scheduledAt])
  @@index([category])
}

model TransportInfo {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  summary      String?
  content      Json
  operator     String?
  website      String?
  phone        String?
  status       ContentStatus @default(DRAFT)
  publishedAt  DateTime?
  scheduledAt  DateTime?
  coverMediaId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdById  String
  updatedById  String?

  createdBy User   @relation("TransportCreatedBy", fields: [createdById], references: [id])
  updatedBy User?  @relation("TransportUpdatedBy", fields: [updatedById], references: [id])
  coverMedia Media? @relation("TransportCoverMedia", fields: [coverMediaId], references: [id])

  @@index([status, publishedAt])
  @@index([scheduledAt])
}

model Media {
  id         String    @id @default(cuid())
  title      String?
  filename   String
  mimeType   String
  size       Int
  url        String
  storageKey String   @unique
  bucket     String
  type       MediaType
  width      Int?
  height     Int?
  duration   Int?
  createdAt  DateTime @default(now())
  createdById String?

  createdBy User? @relation("MediaCreatedBy", fields: [createdById], references: [id])

  articleCovers   Article[]        @relation("ArticleCoverMedia")
  articleDocuments Article[]       @relation("ArticleDocumentMedia")
  eventCovers     Event[]          @relation("EventCoverMedia")
  procedureCovers Procedure[]      @relation("ProcedureCoverMedia")
  directoryCovers DirectoryEntry[] @relation("DirectoryCoverMedia")
  councilPhotos   CouncilMember[]  @relation("CouncilMemberPhoto")
  serviceCovers   MunicipalService[] @relation("ServiceCoverMedia")
  transportCovers TransportInfo[]  @relation("TransportCoverMedia")

  articleMedia    ArticleMedia[]
  eventMedia      EventMedia[]
  procedureMedia  ProcedureMedia[]
  directoryMedia  DirectoryEntryMedia[]
}

model ArticleMedia {
  articleId String
  mediaId   String
  order     Int @default(0)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([articleId, mediaId])
}

model EventMedia {
  eventId String
  mediaId String
  order   Int @default(0)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([eventId, mediaId])
}

model ProcedureMedia {
  procedureId String
  mediaId     String
  order       Int @default(0)

  procedure Procedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  media     Media     @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([procedureId, mediaId])
}

model DirectoryEntryMedia {
  directoryEntryId String
  mediaId          String
  order            Int @default(0)

  directoryEntry DirectoryEntry @relation(fields: [directoryEntryId], references: [id], onDelete: Cascade)
  media          Media          @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@id([directoryEntryId, mediaId])
}

model NewsletterSubscription {
  id              String   @id @default(cuid())
  email           String   @unique
  confirmationToken String?
  confirmedAt     DateTime?
  unsubscribedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  topics NewsletterSubscriptionTopic[]
}

model NewsletterTopic {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions NewsletterSubscriptionTopic[]
}

model NewsletterSubscriptionTopic {
  subscriptionId String
  topicId        String

  subscription NewsletterSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  topic        NewsletterTopic        @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@id([subscriptionId, topicId])
}

model Settings {
  id            String   @id
  siteName      String
  branding      Json
  accessibility Json
  contactEmail  String?
  contactPhone  String?
  address       Json?
  municipalityProfile Json?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model Version {
  id           String   @id @default(cuid())
  entityType   String
  entityId     String
  versionNumber Int
  snapshot     Json
  createdAt    DateTime @default(now())
  createdById  String

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([entityType, entityId])
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime    @default(now())
  userId    String

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entity, entityId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  actionUrl String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String   @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model ExportArchive {
  id          String   @id @default(cuid())
  filename    String
  storageKey  String   @unique
  size        Int
  format      String   @default("zip")
  createdById String
  createdAt   DateTime @default(now())

  createdBy User @relation("ExportCreatedBy", fields: [createdById], references: [id])

  @@index([createdById])
  @@index([createdAt])
}
